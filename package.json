{
  "name": "ai-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "사내 통합 지식 어시스턴트 — RAG + MCP + LangGraph",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "ingest": "tsx --env-file=.env src/ingestion/pipeline.ts",
    "chunk": "tsx --env-file=.env src/ingestion/chunk-pipeline.ts",
    "embed": "tsx --env-file=.env src/ingestion/embed-pipeline.ts",
    "qa": "tsx --env-file=.env src/agents/qa-cli.ts",
    "tickets": "tsx --env-file=.env src/evaluation/list-tickets.ts",
    "eval": "tsx --env-file=.env src/evaluation/run.ts",
    "api:dev": "tsx watch --env-file=.env src/api/index.ts",
    "chroma:up": "docker compose up -d chroma",
    "chroma:down": "docker compose down"
  },
  "dependencies": {
    "chromadb": "^3.4.3",
    "gpt-tokenizer": "^3.4.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
