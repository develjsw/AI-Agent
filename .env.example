# ── LLM APIs ─────────────────────────────────────────
OPENAI_API_KEY=[입력]
ANTHROPIC_API_KEY=[입력]

# ── Vector Store ──────────────────────────────────────────
# Local chroma via docker-compose (default)
CHROMA_URL=http://localhost:8000

# ── Atlassian (Jira / Confluence) ─────────────────────────
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
# Token name suggestion: ai-agent-ingestion-local
ATLASSIAN_SITE=[입력].atlassian.net
ATLASSIAN_EMAIL=[입력]
ATLASSIAN_API_TOKEN=[입력]
