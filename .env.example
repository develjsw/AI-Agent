# MySQL 데이터베이스 계정 정보
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=healthcare
MYSQL_USER=healthcare_user
MYSQL_PASSWORD=

# Prisma 데이터베이스 연결 URL
DATABASE_URL="mysql://healthcare_user:PASSWORD@localhost:33060/healthcare"

# Google Gemini API 키
GOOGLE_API_KEY=

# LiveKit 서버 접속 정보
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
